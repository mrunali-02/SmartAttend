# ==============================================================================
# AI Attendance Assistant - Phase 1 Environment Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# Django Backend Settings
# ------------------------------------------------------------------------------
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*

# PostgreSQL configurations (Leave empty to fallback to local SQLite)
DB_NAME=your_postgresql_db
DB_USER=your_postgresql_user
DB_PASSWORD=your_postgresql_password
DB_HOST=localhost
DB_PORT=5432

# ------------------------------------------------------------------------------
# Vite Frontend Settings
# ------------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api
